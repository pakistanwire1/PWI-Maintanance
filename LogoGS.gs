var LOGO_BASE64 = '';

function getLogoBlob() {
  var bytes = Utilities.base64Decode(LOGO_BASE64);
  return Utilities.newBlob(bytes, 'image/png', 'logo.png');
}

function serveLogo() {
  var bytes = Utilities.base64Decode(LOGO_BASE64);
  var str = '';
  for (var i = 0; i < bytes.length; i++) {
    str += String.fromCharCode(bytes[i] & 0xff);
  }
  var output = ContentService.createTextOutput();
  output.setContent(str);
  output.setMimeType('image/png');
  return output;
}
